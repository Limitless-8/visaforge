# =========================================================
# VisaForge — Environment Variables (example)
# Copy this file to `.env` and fill in real values.
# On Streamlit Cloud, use st.secrets instead (see .streamlit/secrets.toml.example)
# =========================================================

# ---- LLM providers ----
# LLM_PROVIDER options:
#   auto   (default) — prefers xAI if XAI_API_KEY set, else Groq
#   groq   — Groq native SDK
#   xai    — xAI Grok (OpenAI-compatible; requires `openai` package)
#   openai — placeholder for future migration
LLM_PROVIDER=auto

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# xAI (Grok). grok-2-latest is legacy as of 2026; newer options include
# grok-4-1-fast-reasoning, grok-4-1-fast-non-reasoning, grok-4.20.
# XAI_API_KEY=your_xai_api_key_here
# XAI_MODEL=grok-2-latest
# XAI_BASE_URL=https://api.x.ai/v1

# OpenAI (future)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---- Ingestion providers ----
INGESTION_PROVIDER=firecrawl       # firecrawl | tinyfish | playwright | crawlee
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
# TINYFISH_API_KEY=
# PLAYWRIGHT_HEADLESS=true

# ---- Database ----
# Default: local SQLite file. For future Postgres, change to:
# postgresql+psycopg2://user:pass@host:5432/visaforge
DATABASE_URL=sqlite:///data/visaforge.db

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO

# ---- Initial admin (v0.4 auth) ----
# If set, an admin account with these credentials is created on first
# startup. Safe to leave unset after the admin exists — the bootstrap
# is idempotent and will not overwrite an existing account.
# ADMIN_EMAIL=admin@visaforge.local
# ADMIN_PASSWORD=change-me-please
